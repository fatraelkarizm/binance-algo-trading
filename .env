# ============================================================
# BINANCE API CONFIGURATION
# ============================================================
# Dapatkan dari: https://www.binance.com/en/my/settings/api-management
# Enable: Futures Trading | JANGAN enable withdrawal!
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Testnet (true = paper trading, false = live trading)
# Testnet URL: https://testnet.binancefuture.com
BINANCE_TESTNET=true
BINANCE_TESTNET_API_KEY=rdMDYPUEGgB8WPRPY0ypRtNMrT36Ob1zXR66TfSTdYqjnaEZXfAzE8J4oI56Nzn7
BINANCE_TESTNET_API_SECRET=V8A09pOeArPLQq3lYveeGDvvj8maXV6r2aUqBZICLmBtqshqkSdCJF60MaAYT8cx

# ============================================================
# TRADING CONFIGURATION
# ============================================================
# DRY_RUN = true: log orders only, no real execution
DRY_RUN=true

# Trading pairs (comma-separated)
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Leverage (max 5x sesuai PRD)
DEFAULT_LEVERAGE=5

# Timeframe untuk signal (1m, 5m, 15m, 1h, 4h)
SIGNAL_TIMEFRAME=15m

# ============================================================
# RISK MANAGEMENT
# ============================================================
MAX_RISK_PER_TRADE=0.01       # 1% balance per trade
MAX_OPEN_POSITIONS=3          # Max 3 posisi bersamaan
MAX_DAILY_LOSS=0.05           # 5% daily drawdown limit
DEFAULT_STOP_LOSS_PCT=0.02    # 2% stop loss default
DEFAULT_TAKE_PROFIT_PCT=0.04  # 4% take profit (2:1 RR)

# ============================================================
# ALGO ORDER SETTINGS (TWAP / VP)
# ============================================================
# Min order size untuk algo: 10,000 USDT
ALGO_MIN_ORDER_USDT=10000
TWAP_DEFAULT_DURATION=3600    # 1 jam dalam detik
VP_DEFAULT_URGENCY=MEDIUM     # LOW, MEDIUM, HIGH

# ============================================================
# NEWS & SENTIMENT
# ============================================================
# CryptoCompare API: https://min-api.cryptocompare.com/
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_here

# OpenAI (opsional - untuk advanced sentiment)
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================
# SERVER
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
REDIS_URL=redis://localhost:6379

# ============================================================
# DASHBOARD
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/live
